# ═══════════════════════════════════════════════════════════════════
# Debug Together — Backend Environment Configuration
# Copy this file to .env and fill in all values marked with <REQUIRED>
# ═══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Debug Together"
APP_ENV=local
APP_KEY=                          # <REQUIRED> Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
APP_TIMEZONE=UTC
APP_LOCALE=en

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug                   # production: error

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db                        # Use 'db' (Docker service name) or '127.0.0.1' for local
DB_PORT=3306
DB_DATABASE=debug_together
DB_USERNAME=dt_user
DB_PASSWORD=dt_secret             # <REQUIRED> Match docker-compose DB_PASSWORD
DB_ROOT_PASSWORD=rootsecret       # <REQUIRED> Match docker-compose DB_ROOT_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Cache, Queue & Session ────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis                  # Use 'redis' (Docker service name) or '127.0.0.1'
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=dt_

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=                    # <REQUIRED>
MAIL_PASSWORD=                    # <REQUIRED>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@debugtogether.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI Providers ──────────────────────────────────────────────────────────────
AI_PRIMARY=gemini                 # gemini | openai
GEMINI_API_KEY=                   # <REQUIRED> https://aistudio.google.com
GEMINI_MODEL=gemini-1.5-pro
OPENAI_API_KEY=                   # Optional fallback provider
OPENAI_MODEL=gpt-4o

# ── Stripe / Billing ─────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_              # <REQUIRED> Publishable key (safe for frontend)
STRIPE_SECRET=sk_test_           # <REQUIRED> Secret key (backend only)
STRIPE_WEBHOOK_SECRET=whsec_    # <REQUIRED> Stripe Dashboard → Webhooks
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en
STRIPE_PRICE_PRO_MONTHLY=price_  # <REQUIRED> From Stripe Dashboard

# ── Laravel Sanctum ───────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000,127.0.0.1:5173
SESSION_DOMAIN=localhost

# ── Laravel Horizon ───────────────────────────────────────────────────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX=dt_horizon_

# ── GDPR / Privacy ────────────────────────────────────────────────────────────
CONSENT_VERSION=1.0
DATA_RETENTION_DAYS=730           # 2 years default

# ── Monitoring / Error Tracking ───────────────────────────────────────────────
SENTRY_LARAVEL_DSN=               # Optional — https://sentry.io
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local             # local | s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
